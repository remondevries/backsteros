{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BacksterOS",
  "version": "0.1.0",
  "identifier": "com.backsteros.desktop",
  "build": {
    "beforeDevCommand": "./node_modules/.bin/vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm -C .. --filter @backsteros/ui build && ./node_modules/.bin/tsc && ./node_modules/.bin/vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "BacksterOS",
        "width": 1280,
        "height": 840,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 24
        }
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "BacksterOS desktop",
    "longDescription": "Native BacksterOS client — tasks, projects, documents, and letters with offline-first sync.",
    "copyright": "Copyright © BacksterOS",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
