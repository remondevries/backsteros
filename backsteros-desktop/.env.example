# Public API origin (no trailing slash). Used as the default when the Vite-dev
# Dev/Prod switch is off, and always in packaged production builds.
# Local API (recommended for desktop + PowerSync token minting):
VITE_API_URL=http://127.0.0.1:8787

# Clerk publishable key (SPA / Tauri — not Next middleware).
# Required. Without it the app shows a configure-auth screen (no demo fixtures,
# no empty workspace shell).
#
# One Clerk instance covers both Dev and Prod backends (same as the web app).
# The Vite-dev Settings → Sync toggle only switches API origin + local SQLite
# cache (`backsteros-desktop-{dev|prod}-{user}.db`); it does not change this key.
#
# In Clerk Dashboard → Configure → Domains / Allowed origins, add:
#   http://localhost:1420
#   http://127.0.0.1:1420
#   tauri://localhost
#   https://tauri.localhost
#
# Local API CORS must also allow those origins (see backsteros-api/.env
# CORS_ORIGINS). Restart the API after changing CORS.
VITE_CLERK_PUBLISHABLE_KEY=

# Canonical web product URL (optional “Open in browser” later).
# Release builds should set all three VITE_* values explicitly.
VITE_APP_URL=https://backsteros.com/app
