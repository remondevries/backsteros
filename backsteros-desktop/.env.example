VITE_API_URL=https://service.backsteros.com

# Clerk publishable key (SPA / Tauri — not Next middleware).
VITE_CLERK_PUBLISHABLE_KEY=

# Canonical web product URL (optional “Open in browser” later).
VITE_APP_URL=https://backsteros.com/app
