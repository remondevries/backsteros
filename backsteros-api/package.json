{
  "name": "@backsteros/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "pnpm --filter @backsteros/contracts build && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit",
    "test:unit": "tsx --test src/lib/**/*.test.ts src/migration/**/*.test.ts",
    "test:integration": "tsx --test src/integration/**/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env src/db/migrate.ts",
    "db:powersync-setup": "tsx --env-file=.env src/db/powersync-setup.ts",
    "db:powersync-token": "tsx --env-file=.env src/db/powersync-token.ts",
    "db:seed": "tsx --env-file=.env src/db/seed.ts",
    "migration:circle": "tsx --env-file=.env src/migration/cli.ts"
  },
  "dependencies": {
    "@backsteros/contracts": "workspace:*",
    "@clerk/backend": "^1.34.0",
    "@hono/node-server": "^1.14.4",
    "@hono/zod-validator": "^0.4.3",
    "@ts-rest/core": "^3.52.1",
    "@ts-rest/open-api": "^3.52.1",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.12.30",
    "nanoid": "^5.1.5",
    "postgres": "^3.4.7",
    "zod": "^3.24.2",
    "@aws-sdk/client-s3": "^3.848.0",
    "jose": "^6.0.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
