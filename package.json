{
  "name": "backsteros",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @backsteros/api dev",
    "dev:app": "pnpm --filter @backsteros/app dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm --filter @backsteros/contracts build && pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:integration": "pnpm --filter @backsteros/api test:integration",
    "test:e2e": "pnpm --filter @backsteros/app test:e2e",
    "build:app": "pnpm --filter @backsteros/app build",
    "lint:app": "pnpm --filter @backsteros/app lint",
    "typecheck:app": "pnpm --filter @backsteros/app typecheck",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @backsteros/api db:migrate",
    "db:powersync-setup": "pnpm --filter @backsteros/api db:powersync-setup",
    "powersync:up": "docker compose up -d mongo powersync"
  }
}
