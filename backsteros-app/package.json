{
  "name": "@backsteros/app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/build-totem.mjs && node scripts/copy-pdf-worker.mjs && next dev --port ${PORT:-3000}",
    "build": "node scripts/build-totem.mjs && node scripts/copy-pdf-worker.mjs && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test lib/**/*.test.ts",
    "test:e2e": "playwright test",
    "postinstall": "node scripts/build-totem.mjs && node scripts/copy-pdf-worker.mjs"
  },
  "dependencies": {
    "@backsteros/api-client": "workspace:*",
    "@backsteros/contracts": "workspace:*",
    "@briangaoo/totem": "git+https://github.com/briangaoo/totem.git#v1.4.3",
    "@clerk/nextjs": "^6.31.9",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "@powersync/web": "^1.39.0",
    "@primer/octicons-react": "^19.29.1",
    "@replit/codemirror-vim": "^6.3.0",
    "@uiw/react-codemirror": "^4.25.4",
    "chrono-node": "^2.10.0",
    "cmdk": "^1.1.1",
    "next": "16.2.10",
    "pdfjs-dist": "5.4.296",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^22.18.6",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.36.0",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2"
  }
}
