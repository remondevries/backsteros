# Browser-safe Clerk key. Required by the web application.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Server-only Clerk key. Required by Clerk middleware.
CLERK_SECRET_KEY=sk_test_replace_me

# Canonical product and API origins.
NEXT_PUBLIC_APP_URL=https://app.backsteros.com
NEXT_PUBLIC_API_URL=https://service.backsteros.com/api/v1
