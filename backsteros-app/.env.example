# Browser-safe Clerk key. Required by the web application.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Server-only Clerk key. Required by Clerk middleware.
CLERK_SECRET_KEY=sk_test_replace_me

# Canonical product and API origins.
# NEXT_PUBLIC_API_URL is the API origin only (no /api/v1 suffix).
# Production: https://backsteros.com/app with NEXT_PUBLIC_BASE_PATH=/app
# Local next dev: omit NEXT_PUBLIC_BASE_PATH so the app is at the origin root.
NEXT_PUBLIC_APP_URL=http://localhost:5173
NEXT_PUBLIC_API_URL=http://127.0.0.1:8787
# NEXT_PUBLIC_BASE_PATH=/app
