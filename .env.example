# Local dev (copy to backsteros-api/.env)
DATABASE_URL=postgresql://backsteros:backsteros@localhost:5433/backsteros

# Production (Neon) — use the pooled or direct connection string from Neon console
# DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Clerk — from https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Server
PORT=8787
NODE_ENV=development

# Comma-separated origins for CORS (include local Vite ports when testing clients)
CORS_ORIGINS=http://localhost:5173,https://backsteros.com,https://service.backsteros.com
