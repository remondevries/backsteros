# Expo public env (embedded in the JS bundle — restart Metro after changes)
#
# Match desktop when you want the same data (e.g. CA-1 on production):
#   EXPO_PUBLIC_API_URL=https://service.backsteros.com
# Local API:
#   EXPO_PUBLIC_API_URL=http://127.0.0.1:8787
# Physical device + local API: use your LAN IP instead of 127.0.0.1.
EXPO_PUBLIC_API_URL=https://service.backsteros.com
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Optional crash reporting (leave empty for local/dev — Sentry stays disabled)
# EXPO_PUBLIC_SENTRY_DSN=
# When set, install `@sentry/react-native`, add the Expo plugin, and re-run prebuild.

# Prerequisites for Today list:
# - API reachable with Clerk + workspace
# - At least one incomplete task with dueDate on today
# - Optional: POWERSYNC_* on the API for offline SQLite; otherwise REST fallback
