    "@replit/codemirror-vim": "^6.3.0",
    "@uiw/react-codemirror": "^4.25.4",
    "chrono-node": "^2.10.0",
    "cmdk": "^1.1.1",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
